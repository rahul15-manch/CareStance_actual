{
  "phase_1_form": {
    "title": "Know Your Starting Point",
    "description": "Choose what genuinely interests you and what matters most to you in a future career.",
    "fields": [
      {
        "id": "interest_areas",
        "label": "Which areas interest you the most?",
        "type": "multi_select",
        "min_selections": 1,
        "max_selections": 3,
        "required": true,
        "options_source": "interest_selection_mapping",
        "helper_text": "Choose up to three areas that you would enjoy exploring."
      },
      {
        "id": "salary_priority",
        "label": "What matters most to you when choosing a future career?",
        "type": "single_select",
        "required": true,
        "options": [
          {
            "value": "high_salary",
            "label": "High salary and financial growth"
          },
          {
            "value": "balanced",
            "label": "A balance of salary, interest, and stability"
          },
          {
            "value": "meaningful_work",
            "label": "Interest, purpose, and meaningful work"
          },
          {
            "value": "unsure",
            "label": "I am still exploring"
          }
        ]
      }
    ]
  },
  "phase_1_archetype_scoring": {
    "purpose": "Initial archetype signal only. Do not show this as the final archetype before the assessment and Deep Dive.",
    "weights": {
      "interest_areas": 0.8,
      "salary_priority": 0.2
    },
