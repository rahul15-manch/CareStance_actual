  "final_assessment_combination": {
    "phase_1_form_score": 0.2,
    "psychometric_assessment_score": 0.45,
    "careerbuddy_deep_dive_score": 0.35,
    "formula": "final_archetype_score = (0.20 * phase_1_score) + (0.45 * assessment_score) + (0.35 * deep_dive_score)"
